{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.dir-ai/voyager-agent",
  "description": "One universal Voyager: name a goal; it activates senses (repo, net) and runs a live mission.",
  "version": "0.1.0",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@dir-ai/voyager-agent",
      "version": "0.1.0",
      "transport": {
        "type": "stdio"
      },
      "packageArguments": [
        {
          "type": "positional",
          "valueHint": "subcommand",
          "value": "mcp"
        }
      ]
    }
  ],
  "repository": {
    "url": "https://github.com/dir-ai/voyager-agent",
    "source": "github"
  }
}
