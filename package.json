{
  "name": "@dir-ai/voyager-agent",
  "version": "0.4.1",
  "description": "The one universal Voyager: a thin, model-independent orchestrator that turns modular senses (net, repo, …) into CognitiveClaims, runs a live mission, links evidence into causal chains, and acts only through consent. Composition, not a monolith.",
  "type": "module",
  "license": "MIT",
  "author": "dir-ai",
  "homepage": "https://github.com/dir-ai/voyager-agent#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dir-ai/voyager-agent.git"
  },
  "bugs": {
    "url": "https://github.com/dir-ai/voyager-agent/issues"
  },
  "keywords": [
    "ai-agents",
    "orchestration",
    "cognitive-architecture",
    "voyager",
    "senses",
    "model-context-protocol"
  ],
  "bin": {
    "voyager-agent": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "npm run build",
    "test": "npm run build && tsc -p tsconfig.test.json && node --test scripts/run-tests.mjs"
  },
  "dependencies": {
    "@dir-ai/voyager-contract": "^0.2.1",
    "@dir-ai/voyager-net": "^0.3.1",
    "@dir-ai/voyager-repo": "^0.2.1",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@dir-ai/voyager-browser": "^0.2.1",
    "@dir-ai/voyager": "^1.2.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.5.0"
  }
}
